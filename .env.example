# 🍔 Бот доставки еды - Настройки окружения
# Скопируйте этот файл в .env и заполните реальными значениями

# 🔐 Настройки бота
# Получите этот токен у @BotFather в Telegram
BOT_TOKEN=your_bot_token_here

# 👨‍💼 Настройки менеджера
# ID чата в Telegram, куда будут отправляться уведомления о заказах
# Чтобы получить этот ID, добавьте бота в чат и отправьте сообщение, затем проверьте updates
MANAGER_CHAT_ID=your_manager_chat_id_here